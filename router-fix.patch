+reject_multiline_value() {
+  key_name="${1:?Missing key name}"
+  key_value="${2-}"
+
+  case "$key_value" in
+    *"
+"*)
+      printf '%s\n' "ERROR: Multi-line values are not supported for $key_name" >&2
+      return 1
+      ;;
+  esac
+}
+
+yaml_single_quote_value() {
+  key_value="${1-}"
+  printf "'"
+  printf '%s' "$key_value" | sed "s/'/''/g"
+  printf "'\n"
+}
