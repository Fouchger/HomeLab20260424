# ==============================================================================
# File: .gitignore
# Purpose:
#   Ignore local runtime state, secrets, build outputs and editor files.
# ==============================================================================

# Local environment and secrets
.env
*.env
!*.env.example
state/config/.env
state/secrets/passwords.env
state/secrets/passwords/*.env
!state/secrets/passwords.env.example

# Generated state
state/tmp/
state/backups/
state/dr/
state/audit/
state/terraform/*.tfstate
state/terraform/*.tfstate.*
state/ansible/inventory.yml
state/secrets/age/*.key
state/secrets/openbao/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
terraform.tfvars
*.auto.tfvars

# Ansible
*.retry

# Packer
packer_cache/

# OS/editor
.DS_Store
.idea/
.vscode/
*.swp

# Binaries and logs
*.exe
*.dll
*.so
*.dylib
*.log
*.out
coverage.*
